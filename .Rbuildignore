^\.Rproj\.user$
^.*\.Rproj$
^CLAUDE\.md$
^\.claude$
^cerr_to_r_error_strategy\.md$
^inst/plan$
# ── Git/CI metadata in submodules (including nested) ──
^inst/scip/\.git
^inst/soplex/\.git
^inst/scip/src/soplex/\.git
^inst/soplex/src/papilo/\.git
^inst/scip/\.gitlab
^inst/soplex/\.gitlab
^inst/scip/\.github$
^inst/soplex/\.github$
# ── Unused submodule (papilo) ──
^src/papilo
# ── CMake build artifacts (created at install time, never shipped) ──
^inst/scip/build
^inst/soplex/build
^src/sciplib
^src/soplexlib
# ── SCIP directories guarded by BUILD_TESTING (we pass -DBUILD_TESTING=OFF) ──
^inst/scip/applications$
^inst/scip/check$
^inst/scip/examples$
^inst/scip/tests$
^inst/scip/doc$
# ── SCIP non-build directories (not referenced by CMakeLists.txt) ──
^inst/scip/scripts$
^inst/scip/make$
^inst/scip/lint$
^inst/scip/pclint$
^inst/scip/tex$
# ── SoPlex non-build directories (not referenced by CMakeLists.txt) ──
# NOTE: check/ and tests/ are UNCONDITIONALLY add_subdirectory'd — KEEP them
^inst/soplex/doc$
^inst/soplex/make$
^inst/soplex/lint$
^inst/soplex/extra$
^inst/soplex/scripts$
^inst/soplex/settings$
^inst/soplex/build_webdemo\.sh$
^inst/soplex/astylecfg$
^inst/soplex/src/soplex/external/zstr$
# ── Non-source files (docs, changelogs) ──
^inst/scip/CMakePresets\.json$
^inst/scip/INSTALL.*\.md$
^inst/scip/CHANGELOG$
^inst/scip/README\.md$
^inst/scip/suppressions\..*$
^inst/soplex/INSTALL\.md$
^inst/soplex/CHANGELOG$
^inst/soplex/README\.md$
# ── SCIP vendored sources excluded from CMake build ──
^inst/scip/src/amplmp$
^inst/scip/src/rectlu$
# ── pkgdown / docs / github ──
^_pkgdown\.yml$
^docs$
^pkgdown$
^\.github$
^README\.Rmd$
^README\.html$
# ── Misc build artifacts ──
^00install\.out$
^2026-.*\.txt$
^00check\.log$
^tools/cmake_args\.sh$
^scip-.*\.tgz$
^scip_.*\.tar\.gz$
^TODO\.md$
