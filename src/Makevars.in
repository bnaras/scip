CXX_STD = CXX17

# Include paths: config headers first (override templates), then source trees
# config/ has our static soplex/config.h and scip/config.h + scip/scip_export.h
PKG_CPPFLAGS = -Iconfig -Isoplex/src -Iscip/src -Iscip/src/nauty \
    -DNDEBUG -DSCIP_STATIC_DEFINE \
    -DSCIP_LONGINT_FORMAT=\"lld\" \
    -D__STDC_NO_THREADS__

# SCIP needs -ffp-contract=off for floating-point reproducibility (GCC/clang only)
PKG_CFLAGS = @FP_CONTRACT_FLAG@
PKG_CXXFLAGS = @FP_CONTRACT_FLAG@

PKG_LIBS = $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) @PTHREAD_FLAG@

# --- SoPlex sources ---
SOPLEX_SOURCES = \
    soplex/src/soplex/didxset.cpp \
    soplex/src/soplex/idxset.cpp \
    soplex/src/soplex/mpsinput.cpp \
    soplex/src/soplex/nameset.cpp \
    soplex/src/soplex/spxdefines.cpp \
    soplex/src/soplex/spxgithash.cpp \
    soplex/src/soplex/spxid.cpp \
    soplex/src/soplex/spxout.cpp \
    soplex/src/soplex/usertimer.cpp \
    soplex/src/soplex/wallclocktimer.cpp \
    soplex/src/soplex_interface.cpp

