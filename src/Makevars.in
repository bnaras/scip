CXX_STD = CXX17

PKG_CPPFLAGS = -I@RSCIP_LIB_DIR@/include
PKG_CFLAGS = @FP_CONTRACT_FLAG@
PKG_CXXFLAGS = @FP_CONTRACT_FLAG@ $(SHLIB_OPENMP_CXXFLAGS)
PKG_LIBS = @RSCIP_PKG_LIBS@ $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) $(SHLIB_OPENMP_CXXFLAGS) @OPENMP_FLAG@

OBJECTS = scip_wrapper.o scip_init.o r_streams.o
