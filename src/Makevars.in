    scip/src/scip/exprinterpret_cppad.cpp \
    scip/src/scip/presol_milp.cpp \
    scip/src/scip/rational.cpp \
    scip/src/symmetry/build_dejavu_graph.cpp \
    scip/src/symmetry/compute_symmetry_sassy_nauty.cpp

# --- R wrapper ---
R_C_SOURCES = scip_wrapper.c scip_init.c
R_CXX_SOURCES = r_streams.cpp

# Derive object file lists
SOPLEX_OBJECTS = $(SOPLEX_SOURCES:.cpp=.o)
SCIP_C_OBJECTS = $(SCIP_C_SOURCES:.c=.o)
SCIP_CXX_OBJECTS = $(SCIP_CXX_SOURCES:.cpp=.o)
R_C_OBJECTS = $(R_C_SOURCES:.c=.o)
R_CXX_OBJECTS = $(R_CXX_SOURCES:.cpp=.o)

OBJECTS = $(SOPLEX_OBJECTS) $(SCIP_C_OBJECTS) $(SCIP_CXX_OBJECTS) $(R_C_OBJECTS) $(R_CXX_OBJECTS)
