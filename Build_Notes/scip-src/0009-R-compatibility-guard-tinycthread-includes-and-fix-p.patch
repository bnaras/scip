From 1b985f33bb5d95d52805dbfa6adbb7cd6a38d1e8 Mon Sep 17 00:00:00 2001
From: Balasubramanian Narasimhan <b.naras@gmail.com>
Date: Mon, 6 Apr 2026 09:56:24 -0700
Subject: [PATCH 9/9] R compatibility: guard tinycthread includes and fix
 printf in tpi_openmp

- Guard tinycthread.h includes with #ifdef TPI_TNY in symmetry files
  (only needed for tinycthread TPI, not OpenMP TPI)
- Replace printf with Rprintf in tpi_openmp.c and add r_streams.h include
- Update githash.c
---
 src/scip/githash.c                            | 2 +-
 src/symmetry/compute_symmetry_nauty.c         | 2 ++
 src/symmetry/compute_symmetry_sassy_nauty.cpp | 2 ++
 src/tpi/tpi_openmp.c                          | 3 ++-
 4 files changed, 7 insertions(+), 2 deletions(-)

diff --git a/src/scip/githash.c b/src/scip/githash.c
index fac0ce4ebe..af656b5e99 100644
--- a/src/scip/githash.c
+++ b/src/scip/githash.c
@@ -1 +1 @@
-#define SCIP_GITHASH "76a50c97d6-dirty"
+#define SCIP_GITHASH "43a0a60119-dirty"
diff --git a/src/symmetry/compute_symmetry_nauty.c b/src/symmetry/compute_symmetry_nauty.c
index 4a209a92a7..72abfa33c8 100644
--- a/src/symmetry/compute_symmetry_nauty.c
+++ b/src/symmetry/compute_symmetry_nauty.c
@@ -59,7 +59,9 @@
 #include "scip/cons_nonlinear.h"
 #include "scip/cons_linear.h"
 #include "scip/scip_mem.h"
+#ifdef TPI_TNY
 #include "tinycthread/tinycthread.h"
+#endif
 
 /** struct for nauty callback */
 struct NAUTY_Data
diff --git a/src/symmetry/compute_symmetry_sassy_nauty.cpp b/src/symmetry/compute_symmetry_sassy_nauty.cpp
index 67c9978d72..4ce5aae238 100644
--- a/src/symmetry/compute_symmetry_sassy_nauty.cpp
+++ b/src/symmetry/compute_symmetry_sassy_nauty.cpp
@@ -76,7 +76,9 @@
 #include "scip/cons_linear.h"
 #include "scip/scip_mem.h"
 #include "scip/symmetry_graph.h"
+#ifdef TPI_TNY
 #include "tinycthread/tinycthread.h"
+#endif
 
 /** struct for symmetry callback */
 struct SYMMETRY_Data
diff --git a/src/tpi/tpi_openmp.c b/src/tpi/tpi_openmp.c
index cb611338b1..4fb6c5bbdc 100644
--- a/src/tpi/tpi_openmp.c
+++ b/src/tpi/tpi_openmp.c
@@ -36,6 +36,7 @@
 #include "blockmemshell/memory.h"
 #include "scip/pub_message.h"
 #include "scip/pub_misc.h"
+#include "r_streams.h"
 #include <omp.h>
 
 /* macros for direct access */
@@ -583,7 +584,7 @@ SCIP_RETCODE SCIPtpiCollectJobs(
    else
    {
       /* given jobid was not submitted */
-      printf("err1");
+      Rprintf("err1");
       retcode = SCIP_ERROR;
    }
 
-- 
